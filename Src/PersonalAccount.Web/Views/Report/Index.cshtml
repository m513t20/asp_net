@using PersonalAccount.Web.Enums
@model PersonalAccount.Web.Models.ReportFilterViewModel

@{
    ViewData["Title"] = "Отчеты";
}

<div class="container mt-4">
    <h2 class="mb-4">Формирование отчетов</h2>

    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <form asp-action="Index" method="post">
                <div class="row g-3">
                    <div class="col-md-3">
                        <label asp-for="BranchId" class="form-label">Филиал</label>
                        <select asp-for="BranchId" asp-items="Model.Branches" class="form-select" required>
                            <option value="">-- Выберите филиал --</option>
                        </select>
                    </div>
                    
                    <div class="col-md-3">
                        <label asp-for="Start" class="form-label">Начало периода</label>
                        <input asp-for="Start" type="date" class="form-control" required />
                    </div>
                    
                    <div class="col-md-3">
                        <label asp-for="End" class="form-label">Конец периода</label>
                        <input asp-for="End" type="date" class="form-control" required />
                    </div>

                    <div class="col-md-3">
                        <label asp-for="ReportType" class="form-label">Тип отчета</label>
                        <select asp-for="ReportType" asp-items="Html.GetEnumSelectList<ReportTypeEnum>()" class="form-select" required>
                            <option value="">-- Выберите тип --</option>
                        </select>
                    </div>
                </div>
                <div class="row mt-3">
                    <div class="col-12 text-end">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-file-earmark-text"></i> Сформировать
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>


    <div id="reportContainer">
        @if (Model.RevenueReport != null)
        {
            <partial name="_RevenueTable" model="Model.RevenueReport" />
        }
        else if (Model.SellingReport != null)
        {
            <partial name="_SellingTable" model="Model.SellingReport" />
        }
        else if (Model.WorkScheduleReport != null)
        {
            <partial name="_WorkScheduleTable" model="Model.WorkScheduleReport" />
        }
        else if (Context.Request.Method == "POST")
        {
            <div class="alert alert-warning">За выбранный период данные не найдены.</div>
        }
    </div>
</div>