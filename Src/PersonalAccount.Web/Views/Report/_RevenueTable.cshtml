@model IEnumerable<PersonalAccount.Domain.Models.Dto.RevenueDto>

<div class="card shadow-sm">
    <div class="card-header bg-success text-white">
        <h5 class="mb-0">Отчет "Выручка"</h5>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-striped table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Период</th>
                        <th>Наличные</th>
                        <th>Безналично</th>
                        <th>Сумма скидки</th>
                        <th>Итого</th>
                        <th>Праздник</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Period.ToShortDateString()</td>
                            <td>@item.CashAmount.ToString("C")</td>
                            <td>@item.BankAmount.ToString("C")</td>
                            <td>@item.DiscountAmount.ToString("C")</td>
                            <td class="fw-bold">@item.TotalAmount.ToString("C")</td>
                            <td>
                                @if (item.IsHollyday) { <span class="badge bg-danger">Да</span> }
                                else { <span class="badge bg-secondary">Нет</span> }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>